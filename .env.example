# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# For Supabase, paste the full connection string (includes sslmode=require)
DATABASE_URL=postgresql://username:password@localhost:5432/interview_assistant
DB_HOST=localhost
DB_PORT=5432
DB_NAME=interview_assistant
DB_USER=username
DB_PASSWORD=password

# AI Services
OPENAI_API_KEY=your_openai_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here_change_in_production

# OAuth / Identity
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Email SMTP (for OTP/email delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email_username
SMTP_PASS=your_email_app_password
SMTP_FROM="Mightysky <noreply@yourdomain.com>"

# Twilio (for SMS/WhatsApp OTP) - fallback provider
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Telnyx (primary SMS provider)
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_PHONE_NUMBER=+1234567890
TELNYX_PROFILE_ID=your_telnyx_messaging_profile_id

# Ycloud (SMS provider)
YCLOUD_API_KEY=your_ycloud_api_key
YCLOUD_SENDER_ID=YourSenderID

# Demo mode (optional: skips DB, in-memory OTP)
DEMO_MODE=false

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL_SECONDS=3600
ENABLE_CACHING=true

# Security
ENCRYPTION_KEY=your_32_character_encryption_key

# PWA Configuration
PWA_NAME=Interview Answer Assistant
PWA_SHORT_NAME=IAA
PWA_THEME_COLOR=#3b82f6
