# Client env
# Point to your API base (backend). For Android emulator hitting local backend, use http://10.0.2.2:3001
VITE_API_URL=http://localhost:3001

# Firebase Analytics Configuration (get these from your Firebase Project Settings)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=523353647
VITE_FIREBASE_APP_ID=1:523353647:web:your_app_id
VITE_GA_MEASUREMENT_ID=G-523353647
